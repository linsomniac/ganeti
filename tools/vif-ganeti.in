if [ -x "@XEN_CONFIG_DIR@/scripts/vif-custom" ]; then
  exec @XEN_CONFIG_DIR@/scripts/vif-custom "$@"
fi

source @PKGLIBDIR@/net-common

# Parse the vif interface name (e.g. "vif1.0") that Xen passes as $vif
# when it invokes the vif-script to extract domid and devid.
dev_=${vif#vif}
domid=${dev_%.*}
devid=${dev_#*.}
domname=$(xl domname "${domid}")

source "${RUN_DIR}/xen-hypervisor/nic/${domname}/${devid}"

# Fall back to values derived from the vif name in case the NIC state
# file does not define them.
INTERFACE=${INTERFACE:-${vif}}
INSTANCE=${INSTANCE:-${domname}}

# Xen only calls the vif-script on interface creation; there is no
# corresponding teardown callback.
ACTION=up

check

# This is only a wrapper script which will call the relevant action
# script for the given network mode.
#
# Built-in modes check for a user override in ${CONF_DIR}/network/${MODE}/
# first, then fall back to the versioned built-in in ${PKGLIBDIR}/network/${MODE}/.
#
# ext mode is not supported under Xen.
if [ -x "${CONF_DIR}/network/${MODE}/up" ]; then
  exec ${CONF_DIR}/network/${MODE}/up
elif [ -x "${PKGLIBDIR}/network/${MODE}/up" ]; then
  exec ${PKGLIBDIR}/network/${MODE}/up
else
  echo "Error: no up script for network type ${MODE} found" >&2
  exit 1
fi
